# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environments ───────────────────────────────────────────────────────
.venv*/
venv/
env/
ENV/
.env

# ── Distribution / packaging ───────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
.eggs/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Type checkers / linters ────────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── ML model weights (large binary files) ─────────────────────────────────────
