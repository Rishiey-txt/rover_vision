*.pt
*.pth
*.onnx
*.tflite
*.engine

# ── Snapshots / output videos ─────────────────────────────────────────────────
snapshots/
*.mp4
*.avi
*.mov

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── Editors / IDEs ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Streamlit ─────────────────────────────────────────────────────────────────
